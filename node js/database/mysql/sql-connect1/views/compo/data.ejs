<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Database Data</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">

  <h1 class="text-2xl font-bold mb-6 text-center">Stored Form Data</h1>

  <div class="flex flex-col gap-4 max-w-xl mx-auto">

    <% data.forEach(rows => { %>
      <div class="bg-white shadow-xl rounded p-5 border flex flex-col gap-1">

        <p><strong>Name:</strong> <%= rows.name %></p>
        <p><strong>Email:</strong> <%= rows.email %></p>
        <p><strong>Phone:</strong> <%= rows.phone %></p>
        <p><strong>Subject:</strong> <%= rows.subject %></p>
        <p><strong>Company:</strong> <%= rows.company %></p>
        <p><strong>Message:</strong> <%= rows.message %></p>

        <div class="mt-3 flex gap-3">
          
          <!-- UPDATE BUTTON -->
          <a href="/update/<%= rows.id %>" 
             class="px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700">
            Update
          </a>

        <a href="/delete/<%= rows.id %>"
   onclick="return confirm('Are you sure you want to delete this record?');"
   class="px-3 py-1 bg-red-600 text-white rounded hover:bg-red-700">
  Delete
</a>

        </div>

      </div>
    <% }) %>

  </div>

</body>
</html>
