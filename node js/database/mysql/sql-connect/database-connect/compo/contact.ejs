<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Advanced Contact Page</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 text-gray-800">

  <section class="max-w-4xl mx-auto p-10">
    <h2 class="text-4xl font-bold text-center mb-4">Get in Touch</h2>
    <p class="text-center text-gray-500 mb 10">
      We would love to hear from you. Fill out the form below and our team will respond shortly.
    </p>

    <div class="bg-white shadow-xl rounded-xl p-8">
      <form class="grid grid-cols-1 md:grid-cols-2 gap-6" method="post" action="/contact">

        <div>
          <label class="block font-semibold mb-1">Full Name</label>
          <input type="text" name="full_name" class="w-full p-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Enter full name">
        </div>

        <div>
          <label class="block font-semibold mb-1">Email Address</label>
          <input type="email" name="email" class="w-full p-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Enter email">
        </div>

        <div>
          <label class="block font-semibold mb-1">Phone Number</label>
          <input type="text" name="phone" class="w-full p-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Enter phone number">
        </div>

        <div>
          <label class="block font-semibold mb-1">Subject</label>
          <input type="text" name="subject" class="w-full p-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Enter subject">
        </div>

        <div>
          <label class="block font-semibold mb-1">Company / Organization</label>
          <input type="text" name="company" class="w-full p-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Enter organization name">
        </div>

        <div class="md:col-span-2">
          <label class="block font-semibold mb-1">Message</label>
          <textarea rows="5" name="message" class="w-full p-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Write your message here..."></textarea>
        </div>

        <div class="md:col-span-2 text-center">
          <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-full transition">
            Send Message
          </button>
        </div>

      </form>
    </div>
  </section>

</body>
</html>
