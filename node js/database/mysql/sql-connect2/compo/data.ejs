<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Forms Data</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen py-10">

  <div class="max-w-3xl mx-auto bg-white shadow-lg rounded-lg p-6">
    
    <h2 class="text-2xl font-semibold mb-5 text-gray-800">Stored Data</h2>

    <% forms.forEach(rows =>{ %>

      <div class="border rounded-lg p-4 mb-4 bg-gray-50 flex justify-between items-center">
        
        <div>
          <p class="text-gray-700"><span class="font-semibold">Name:</span><%= rows.name %></p>
          <p class="text-gray-700"><span class="font-semibold">Email:</span> <%= rows.email %></p>
        </div>
        

        <div class="flex gap-3"> 

          <!-- UPDATE BUTTON -->
           <a href="update/<%= rows.id %>"
            onclick="return confirm ('are want to update date?')"
             class="px-4 py-1 bg-blue-600 text-white rounded hover:bg-blue-700 transition">
            Update
          </a>

          <!-- DELETE BUTTON -->
          <a href="delete/<%= rows.id %>"
            onclick="return confirm('Are you sure you want to delete this entry?');"
             class="px-4 py-1 bg-red-600 text-white rounded hover:bg-red-700 transition">
            Delete
          </a>

        </div>

      </div>

 <% }) %>

  </div>

</body>

</html>
