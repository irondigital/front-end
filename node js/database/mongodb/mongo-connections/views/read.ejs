<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>All Contacts</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-6">

  <div class="max-w-3xl mx-auto bg-white shadow-md rounded-lg p-6">
    <h1 class="text-2xl font-bold mb-4 text-center">All Contacts</h1>

    <table class="min-w-full border border-gray-300">
      <thead class="bg-gray-200">
        <tr>
          <th class="border px-4 py-2">Name</th>
          <th class="border px-4 py-2">Email</th>
          <th class="border px-4 py-2">Subject</th>
          <th class="border px-4 py-2">Message</th>
          
        </tr>
      </thead>
      <tbody>
  <% contacts.forEach(contact => { %>
    <tr class="text-center">
      <td class="border px-4 py-2"><%= contact.name %></td>
      <td class="border px-4 py-2"><%= contact.email %></td>
      <td class="border px-4 py-2"><%= contact.subject %></td>
      <td class="border px-4 py-2"><%= contact.message %></td>
      
      <td class="border px-4 py-2 flex justify-center gap-2">
        <!-- Update Button -->
        <a href="/update/<%= contact._id %>" 
           class="bg-yellow-400 text-white px-3 py-1 rounded hover:bg-yellow-500">Update</a>

        <!-- Delete Button -->
        <form action="/delete/<%= contact._id %>" method="POST" onsubmit="return confirm('Are you sure?')">
          <button class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600" type="submit">Delete</button>
        </form>
      </td>
    </tr>
  <% }) %>
</tbody>

    </table>
  </div>

</body>
</html>
