<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>studipro Admin Panel</title>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
  <link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
/>

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

  <!-- Admin Navbar -->
  <nav class="bg-white shadow-md">
    <div class="max-w-7xl mx-auto p-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <!-- Logo -->
        <div class="flex-shrink-0 flex items-center">
          <img class="h-10 w-10 rounded-full" src="https://tse4.mm.bing.net/th/id/OIP._maybKK3q658roaonQv89gHaHa?pid=Api&P=0&h=180" alt="EduPro Logo">
          <span class="ml-2 font-bold text-xl text-gray-800"> StudiPRO Admin</span>
        </div>

        <!-- Navigation Links -->
        <div class="hidden md:flex space-x-6">
          <a href="/admin/dashboard" class="text-gray-700 hover:text-blue-600 font-medium">Dashboard</a>
          <a href="/admin/courses" class="text-gray-700 hover:text-blue-600 font-medium">Courses</a>
          <a href="/admin/users" class="text-gray-700 hover:text-blue-600 font-medium">Users</a>
          <a href="/admin/logout" class="text-gray-700 hover:text-red-600 font-medium">Logout</a>
        </div>

        <!-- Mobile Menu Placeholder (Optional) -->
        <div class="md:hidden flex items-center">
          <span class="text-gray-500 font-semibold">Menu</span>
        </div>
      </div>
    </div>
  </nav>

  <!-- Page Content -->


</body>
</html>
