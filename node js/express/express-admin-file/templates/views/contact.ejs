
  <%- include("../partials/navbar") %>




<section class="bg-white py-20">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Heading -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800">
        Get in Touch with StudiPRO
      </h2>
      <p class="mt-4 text-gray-600 max-w-2xl mx-auto">
        Have questions about courses, pricing, or career guidance?
        Our team is here to help you.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid lg:grid-cols-2 gap-12">

      <!-- Contact Info -->
      <div class="space-y-8">

        <div>
          <h3 class="text-xl font-semibold text-gray-800">
            Contact Information
          </h3>
          <p class="mt-3 text-gray-600">
            Reach out to us through any of the following methods.
          </p>
        </div>

        <!-- Info Cards -->
        <div class="space-y-6">

          <div class="flex items-start gap-4">
            <div class="bg-blue-100 text-blue-600 p-3 rounded-lg">
              📍
            </div>
            <div>
              <h4 class="font-semibold text-gray-800">Office Address</h4>
              <p class="text-gray-600">
                StudiPRO Learning Pvt. Ltd.<br>
                Rajkot, Gujrat, India
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="bg-blue-100 text-blue-600 p-3 rounded-lg">
              📧
            </div>
            <div>
              <h4 class="font-semibold text-gray-800">Email</h4>
              <p class="text-gray-600">
                support@StudiPRO.com<br>
                careers@StudiPRO.com
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="bg-blue-100 text-blue-600 p-3 rounded-lg">
              📞
            </div>
            <div>
              <h4 class="font-semibold text-gray-800">Phone</h4>
              <p class="text-gray-600">
                +91 91730 34463<br>
                Mon – Sat (9:00 AM – 7:00 PM)
              </p>
            </div>
          </div>

        </div>

        <!-- Trust Line -->
        <div class="bg-gray-50 p-6 rounded-xl">
          <p class="text-gray-700 font-medium">
            Trusted by 50,000+ students across India 🇮🇳
          </p>
          <p class="text-sm text-gray-600 mt-2">
            Average response time: under 24 hours
          </p>
        </div>

      </div>

      <!-- Contact Form -->
      <div class="bg-gray-50 p-8 rounded-2xl shadow">

        <h3 class="text-2xl font-semibold text-gray-800 mb-6">
          Send Us a Message
        </h3>

        <form class="space-y-5" method="post" action="/contact">

          <div>
            <label class="block text-sm font-medium text-gray-700">
              Full Name
            </label>
            <input
              type="text"
              placeholder="Your name"
              name="name"
              class="mt-2 w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700">
              Email Address
            </label>
            <input
              type="email"
              name="email"
              placeholder="you@example.com"
              class="mt-2 w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700">
              Subject
            </label>
            <input
             name="subject"
              type="text"
              placeholder="Course / Pricing / Support"
              class="mt-2 w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700">
              Message
            </label>
            <textarea
              rows="4"
              name="message"
              placeholder="Write your message here..."
              class="mt-2 w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
            Send Message
          </button>

        </form>
      </div>

    </div>

  </div>
</section>
<%- include("../partials/footer") %>

