<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Page Not Found - EduPro</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center h-screen">

  <div class="text-center p-8 bg-white rounded-2xl shadow-lg max-w-md">
    <h1 class="text-6xl font-bold text-blue-600 mb-4">404</h1>
    <h2 class="text-2xl font-semibold text-gray-800 mb-4">Oops! Page Not Found</h2>
    <p class="text-gray-600 mb-6">
      The page you are looking for does not exist. It might have been removed or the URL is incorrect.
    </p>
    <a href="/"
       class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition">
       Go Back Home
    </a>
  </div>

</body>
</html>
