<%- include("../partials/navbar") %>

<div class="max-w-4xl mx-auto py-12 px-4">
  <div class="bg-white rounded-2xl shadow-lg p-8">

    <h1 class="text-3xl font-bold mb-2 text-blue-600">
    
    </h1>
    <p class="text-gray-600 mb-8">
      Fill the form below to complete your enrollment
    </p>

   <form action="/enroll" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-6">

  <div>
    <label class="block text-sm font-medium mb-1">Full Name</label>
    <input type="text" name="name" required
      class="w-full border rounded-lg px-4 py-2 focus:outline-blue-500">
  </div>

  <div>
    <label class="block text-sm font-medium mb-1">Email</label>
    <input type="email" name="email" required
      class="w-full border rounded-lg px-4 py-2 focus:outline-blue-500">
  </div>

  <div>
    <label class="block text-sm font-medium mb-1">Phone</label>
    <input type="tel" name="phone" required
      class="w-full border rounded-lg px-4 py-2 focus:outline-blue-500">
  </div>

  <div>
    <label class="block text-sm font-medium mb-1">Course</label>
    <input type="text" name="course" 
      class="w-full bg-gray-100 border rounded-lg px-4 py-2">
  </div>

  <div class="md:col-span-2">
    <label class="block text-sm font-medium mb-1">Message (optional)</label>
    <textarea name="message" rows="4"
      class="w-full border rounded-lg px-4 py-2 focus:outline-blue-500"></textarea>
  </div>

  <div class="md:col-span-2 flex justify-end">
    <button type="submit"
    onclick="btn()"
      class="bg-blue-600 text-white px-8 py-3 rounded-xl hover:bg-blue-700 transition hello">
      Confirm Enrollment
    </button>
  </div>

</form>

  </div>
</div>

<%- include("../partials/footer") %>

<script>
  function btn(){
    const btn = document.querySelector('.hello');
    btn.addEventListener('click', () => {
      alert("Enrollment successful!");
    });
  }
</script>
