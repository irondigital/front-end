<%- include("../../../partials/admin/navbar") %>

<div class="flex min-h-screen">
  <%- include("../../../partials/admin/sidebar") %>

  <main class="flex-1 bg-gray-100 p-6">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-800">Admin Activity Logs</h1>
        <p class="text-sm text-gray-500">
          Track all admin actions for security & auditing
        </p>
      </div>

      <div class="flex gap-3 mt-4 md:mt-0">
        <input
          type="text"
          placeholder="Search action or admin..."
          class="bg-white border rounded-lg px-4 py-2 text-sm shadow focus:outline-none"
        />
        <select class="bg-white border rounded-lg px-4 py-2 text-sm shadow">
          <option>All Modules</option>
          <option>Courses</option>
          <option>Payments</option>
          <option>Users</option>
          <option>Settings</option>
        </select>
        <select class="bg-white border rounded-lg px-4 py-2 text-sm shadow">
          <option>All Severity</option>
          <option>Low</option>
          <option>Medium</option>
          <option>High</option>
        </select>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-6 mb-6">
      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Total Logs</h3>
        <p class="text-3xl font-bold text-gray-800">1,248</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Today</h3>
        <p class="text-3xl font-bold text-indigo-600">42</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">High Severity</h3>
        <p class="text-3xl font-bold text-red-600">8</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Unique Admins</h3>
        <p class="text-3xl font-bold text-green-600">6</p>
      </div>
    </div>

    <!-- Logs Table -->
    <div class="bg-white rounded-2xl shadow overflow-hidden">

      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-600">
          <tr>
            <th class="p-4 text-left">Admin</th>
            <th class="p-4 text-left">Action</th>
            <th class="p-4 text-left">Module</th>
            <th class="p-4 text-left">IP / Device</th>
            <th class="p-4 text-left">Severity</th>
            <th class="p-4 text-left">Date</th>
          </tr>
        </thead>

        <tbody class="text-gray-700">

          <tr class="border-t hover:bg-gray-50 transition">
            <td class="p-4">
              <p class="font-semibold">Super Admin</p>
              <p class="text-xs text-gray-500">admin@edupro.com</p>
            </td>
            <td class="p-4">
              <p class="font-medium">Created Course</p>
              <p class="text-xs text-gray-500">
                React Advanced added
              </p>
            </td>
            <td class="p-4">Course Management</td>
            <td class="p-4">
              <p class="text-xs">192.168.1.12</p>
              <p class="text-xs text-gray-500">Chrome · Windows</p>
            </td>
            <td class="p-4">
              <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs">
                Low
              </span>
            </td>
            <td class="p-4">07 Jan 2026, 10:30 AM</td>
          </tr>

          <tr class="border-t hover:bg-gray-50 transition">
            <td class="p-4">
              <p class="font-semibold">Content Manager</p>
              <p class="text-xs text-gray-500">content@edupro.com</p>
            </td>
            <td class="p-4">
              <p class="font-medium">Updated Pricing</p>
              <p class="text-xs text-gray-500">
                Pro plan price changed
              </p>
            </td>
            <td class="p-4">Payments</td>
            <td class="p-4">
              <p class="text-xs">192.168.1.25</p>
              <p class="text-xs text-gray-500">Firefox · Linux</p>
            </td>
            <td class="p-4">
              <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-xs">
                Medium
              </span>
            </td>
            <td class="p-4">07 Jan 2026, 09:15 AM</td>
          </tr>

        </tbody>
      </table>

      <!-- Pagination -->
      <div class="flex justify-between items-center p-4 text-sm text-gray-500">
        <span>Showing 1–10 of 1,248</span>
        <div class="flex gap-2">
          <button class="px-3 py-1 border rounded">Prev</button>
          <button class="px-3 py-1 border rounded bg-gray-100">1</button>
          <button class="px-3 py-1 border rounded">2</button>
          <button class="px-3 py-1 border rounded">Next</button>
        </div>
      </div>

    </div>

  </main>
</div>
