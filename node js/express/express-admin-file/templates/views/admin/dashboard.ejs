<%- include("../../partials/admin/navbar") %>

<div class="flex">
  <%- include("../../partials/admin/sidebar") %>

  <!-- Main Content -->
  <main class="flex-1 bg-gray-100 p-6 space-y-6">

    <!-- Page Header -->
    <div>
      <h1 class="text-3xl font-bold text-gray-800">Dashboard</h1>
      <p class="text-gray-600 mt-1">Welcome back to StudiPRO Admin Panel</p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Courses Card -->
      <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-blue-600">
        <h3 class="text-sm font-medium text-gray-500">Total Courses</h3>
        <p class="text-3xl font-bold text-gray-800 mt-2"><%= totalCourses %></p>
        <p class="text-xs text-gray-400 mt-1">Published & Draft</p>
      </div>

      <!-- Users Card -->
      <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-green-600">
        <h3 class="text-sm font-medium text-gray-500">Total Users</h3>
        <p class="text-3xl font-bold text-gray-800 mt-2"><%= totalUsers %></p>
        <p class="text-xs text-gray-400 mt-1">Students & Admins</p>
      </div>

      <!-- Messages Card -->
      <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-purple-600">
        <h3 class="text-sm font-medium text-gray-500">Total Messages</h3>
        <p class="text-3xl font-bold text-gray-800 mt-2"><%= totalMessages %></p>
        <p class="text-xs text-gray-400 mt-1">Contact inquiries</p>
      </div>

    </div>

    <!-- Overview Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Platform Overview -->
      <div class="bg-white shadow-md rounded-xl p-6">
        <h2 class="text-xl font-semibold text-gray-800 mb-4">Platform Overview</h2>
        <ul class="space-y-3 text-gray-600">
          <li class="flex justify-between">
            <span>Active Courses</span>
            <span class="font-semibold text-gray-800"><%= totalCourses %></span>
          </li>
          <li class="flex justify-between">
            <span>Registered Users</span>
            <span class="font-semibold text-gray-800"><%= totalUsers %></span>
          </li>
          <li class="flex justify-between">
            <span>Total Messages</span>
            <span class="font-semibold text-gray-800"><%= totalMessages %></span>
          </li>
        </ul>
      </div>

      <!-- Admin Info -->
      <div class="bg-white shadow-md rounded-xl p-6">
        <h2 class="text-xl font-semibold text-gray-800 mb-4">Admin Information</h2>
        <div class="space-y-2 text-gray-600">
          <p><strong>Platform:</strong> StudiPRO</p>
          <p><strong>Role:</strong> Administrator</p>
          <p><strong>Status:</strong> <span class="text-green-600 font-semibold">Active</span></p>
        </div>
      </div>

    </div>

   

  </main>
</div>
 <!-- Footer Note -->
    <div class="text-gray-600  text-center text-xl font-bold">
     © 2026 StudiPRO. All rights reserved.
    </div>
