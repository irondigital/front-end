<%- include("../../../partials/admin/navbar") %>

<div class="flex min-h-screen">
  <%- include("../../../partials/admin/sidebar") %>

  <main class="flex-1 bg-gray-100 p-6">

    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-800">
          Ticket #1023
        </h1>
        <p class="text-sm text-gray-500">
          Payment Issue · Created on 07 Jan 2026
        </p>
      </div>

      <span class="bg-yellow-100 text-yellow-700 px-4 py-1 rounded-full text-sm">
        Open
      </span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- ================= LEFT: CONVERSATION ================= -->
      <div class="lg:col-span-2 space-y-4">

        <!-- Student Message -->
        <div class="bg-white p-5 rounded-xl shadow">
          <p class="text-sm text-gray-500 mb-1">
            Anjali Patel · Student
          </p>
          <p class="text-gray-700">
            My payment was deducted but the course is not activated yet.
          </p>
          <p class="text-xs text-gray-400 mt-2">
            07 Jan 2026, 09:12 AM
          </p>
        </div>

        <!-- Admin Reply -->
        <div class="bg-blue-50 p-5 rounded-xl shadow border-l-4 border-blue-600">
          <p class="text-sm text-gray-500 mb-1">
            You · Admin
          </p>
          <p class="text-gray-700">
            Thanks for reaching out. We are checking your payment details and will
            update you shortly.
          </p>
          <p class="text-xs text-gray-400 mt-2">
            07 Jan 2026, 10:05 AM
          </p>
        </div>

        <!-- Reply Box -->
        <div class="bg-white p-5 rounded-xl shadow">
          <h3 class="font-semibold mb-2">Reply to Student</h3>

          <textarea
            rows="4"
            class="w-full border rounded-lg p-3 text-sm"
            placeholder="Write your response..."
          ></textarea>

          <div class="flex gap-3 mt-4">
            <button class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
              Send Reply
            </button>
            <button class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700">
              Mark as Resolved
            </button>
          </div>
        </div>
      </div>

      <!-- ================= RIGHT: TICKET INFO ================= -->
      <div class="space-y-4">

        <!-- Ticket Info -->
        <div class="bg-white p-5 rounded-xl shadow">
          <h3 class="font-semibold mb-3">Ticket Information</h3>

          <div class="text-sm space-y-2">
            <p><strong>Status:</strong>
              <span class="text-yellow-600">Open</span>
            </p>
            <p><strong>Priority:</strong>
              <span class="text-red-600">High</span>
            </p>
            <p><strong>Category:</strong> Payments</p>
            <p><strong>Assigned To:</strong> Support Admin</p>
          </div>
        </div>

        <!-- Student Info -->
        <div class="bg-white p-5 rounded-xl shadow">
          <h3 class="font-semibold mb-3">Student Details</h3>

          <div class="text-sm space-y-2">
            <p><strong>Name:</strong> Anjali Patel</p>
            <p><strong>Email:</strong> anjali@gmail.com</p>
            <p><strong>Course:</strong> React Advanced</p>
            <p><strong>Plan:</strong> Pro</p>
          </div>
        </div>

        <!-- Internal Notes -->
        <div class="bg-white p-5 rounded-xl shadow">
          <h3 class="font-semibold mb-2">Internal Notes</h3>

          <textarea
            rows="3"
            class="w-full border rounded-lg p-3 text-sm"
            placeholder="Notes visible only to admins..."
          ></textarea>

          <button class="mt-3 bg-gray-800 text-white px-4 py-2 rounded-lg text-sm hover:bg-black">
            Save Note
          </button>
        </div>

      </div>
    </div>

  </main>
</div>
