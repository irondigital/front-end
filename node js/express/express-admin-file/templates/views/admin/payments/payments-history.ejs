<%- include("../../../partials/admin/navbar") %>
<div class="flex min-h-screen">
  <%- include("../../../partials/admin/sidebar") %>

  <main class="flex-1 p-6 bg-gray-100">

    <!-- HEADER -->
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-800">Payment History</h1>
      <p class="text-sm text-gray-500">
        View all transactions made by students
      </p>
    </div>

    <!-- ================= FILTERS ================= -->
    <div class="bg-white p-4 rounded-xl shadow mb-6 grid grid-cols-1 md:grid-cols-5 gap-4">
      <input
        type="text"
        placeholder="Search student..."
        class="border p-2 rounded-lg text-sm"
      />
      <select class="border p-2 rounded-lg text-sm">
        <option>All Courses</option>
        <option>React Mastery</option>
        <option>Node.js Pro</option>
        <option>Angular Basics</option>
      </select>
      <select class="border p-2 rounded-lg text-sm">
        <option>All Status</option>
        <option>Paid</option>
        <option>Pending</option>
        <option>Refunded</option>
      </select>
      <select class="border p-2 rounded-lg text-sm">
        <option>All Methods</option>
        <option>UPI</option>
        <option>Card</option>
        <option>Net Banking</option>
      </select>
      <button class="bg-blue-600 text-white rounded-lg text-sm hover:bg-blue-700">
        Apply
      </button>
    </div>

    <!-- ================= PAYMENT HISTORY TABLE ================= -->
    <div class="bg-white rounded-xl shadow overflow-x-auto">
      <table class="w-full text-sm min-w-[800px]">
        <thead class="bg-gray-50 text-gray-600">
          <tr>
            <th class="p-4 text-left">Student</th>
            <th class="p-4">Email</th>
            <th class="p-4">Course</th>
            <th class="p-4">Plan</th>
            <th class="p-4">Amount</th>
            <th class="p-4">Method</th>
            <th class="p-4">Status</th>
            <th class="p-4">Transaction ID</th>
            <th class="p-4">Date</th>
            <th class="p-4 text-center">Actions</th>
          </tr>
        </thead>

        <tbody class="text-gray-700">

          <!-- ROW 1 -->
          <tr class="border-t hover:bg-gray-50">
            <td class="p-4 font-semibold">Amit Sharma</td>
            <td class="p-4 text-xs text-gray-500">amit@gmail.com</td>
            <td class="p-4 text-center">React Mastery</td>
            <td class="p-4 text-center">Pro</td>
            <td class="p-4 text-center font-semibold">₹1,499</td>
            <td class="p-4 text-center text-xs">UPI</td>
            <td class="p-4 text-center">
              <span class="bg-green-100 text-green-700 px-2 py-1 rounded-full text-xs">
                Paid
              </span>
            </td>
            <td class="p-4 text-center text-xs">TXN12345678</td>
            <td class="p-4 text-center text-xs">10 Jan 2026, 10:30 AM</td>
            <td class="p-4 text-center space-x-2">
              <a href="#" class="text-blue-600 hover:underline">Invoice</a>
              <a href="#" class="text-red-600 hover:underline">Refund</a>
              <a href="#" class="text-purple-600 hover:underline">Contact</a>
            </td>
          </tr>

          <!-- ROW 2 -->
          <tr class="border-t hover:bg-gray-50">
            <td class="p-4 font-semibold">Neha Patel</td>
            <td class="p-4 text-xs text-gray-500">neha@gmail.com</td>
            <td class="p-4 text-center">Node.js Pro</td>
            <td class="p-4 text-center">Premium</td>
            <td class="p-4 text-center font-semibold">₹2,999</td>
            <td class="p-4 text-center text-xs">Card</td>
            <td class="p-4 text-center">
              <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded-full text-xs">
                Pending
              </span>
            </td>
            <td class="p-4 text-center text-xs">TXN87654321</td>
            <td class="p-4 text-center text-xs">12 Jan 2026, 02:15 PM</td>
            <td class="p-4 text-center space-x-2">
              <a href="#" class="text-blue-600 hover:underline">Invoice</a>
              <a href="#" class="text-red-600 hover:underline">Refund</a>
              <a href="#" class="text-purple-600 hover:underline">Contact</a>
            </td>
          </tr>

          <!-- ROW 3 -->
          <tr class="border-t hover:bg-gray-50">
            <td class="p-4 font-semibold">Rahul Verma</td>
            <td class="p-4 text-xs text-gray-500">rahul@gmail.com</td>
            <td class="p-4 text-center">Angular Basics</td>
            <td class="p-4 text-center">Basic</td>
            <td class="p-4 text-center font-semibold">₹499</td>
            <td class="p-4 text-center text-xs">Net Banking</td>
            <td class="p-4 text-center">
              <span class="bg-red-100 text-red-700 px-2 py-1 rounded-full text-xs">
                Refunded
              </span>
            </td>
            <td class="p-4 text-center text-xs">TXN11223344</td>
            <td class="p-4 text-center text-xs">15 Jan 2026, 11:00 AM</td>
            <td class="p-4 text-center space-x-2 text-gray-500">
              <span class="text-sm">No actions</span>
            </td>
          </tr>

        </tbody>
      </table>
    </div>

    <!-- ================= PAGINATION ================= -->
    <div class="flex justify-between items-center mt-6 text-sm">
      <p class="text-gray-500">Showing 1–10 of 420 transactions</p>

      <div class="flex gap-2">
        <button class="px-3 py-1 border rounded-lg">Prev</button>
        <button class="px-3 py-1 border rounded-lg bg-blue-600 text-white">1</button>
        <button class="px-3 py-1 border rounded-lg">2</button>
        <button class="px-3 py-1 border rounded-lg">Next</button>
      </div>
    </div>

  </main>
</div>
