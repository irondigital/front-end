
<%- include("../../../partials/admin/navbar") %>

<div class="flex min-h-screen">
  <%- include("../../../partials/admin/sidebar") %>

  <main class="flex-1 bg-gray-100 p-6 space-y-6">

    <!-- Page Header -->
    <div>
      <h1 class="text-3xl font-bold text-gray-800">Revenue Analytics</h1>
      <p class="text-gray-600">Monthly revenue overview</p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white p-6 rounded-xl shadow">
        <p class="text-gray-500 text-sm">Total Revenue</p>
        <h2 class="text-2xl font-bold">₹4,50,000</h2>
      </div>

      <div class="bg-white p-6 rounded-xl shadow">
        <p class="text-gray-500 text-sm">This Month</p>
        <h2 class="text-2xl font-bold">₹75,000</h2>
      </div>

      <div class="bg-white p-6 rounded-xl shadow">
        <p class="text-gray-500 text-sm">Pending Payments</p>
        <h2 class="text-2xl font-bold">₹12,000</h2>
      </div>
    </div>

    <!-- Chart Section -->
    <div class="bg-white p-6 rounded-xl shadow">
      <h2 class="text-xl font-semibold mb-4">Revenue Chart</h2>

      <canvas id="revenueChart" height="120"></canvas>
    </div>

  </main>
</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  const ctx = document.getElementById('revenueChart').getContext('2d');

  new Chart(ctx, {
    type: 'line',
    data: {
      labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'],
      datasets: [{
        label: 'Revenue (₹)',
        data: [40000, 55000, 48000, 70000, 65000, 80000, 75000],
        borderWidth: 3,
        fill: true,
        tension: 0.4,
        backgroundColor: 'rgba(37, 99, 235, 0.1)',
        borderColor: 'rgba(37, 99, 235, 1)',
        pointBackgroundColor: '#2563eb'
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: {
          display: true
        }
      },
      scales: {
        y: {
          beginAtZero: true
        }
      }
    }
  });
</script>
