<%- include("../../../partials/admin/navbar") %>

<div class="flex min-h-screen">
  <%- include("../../../partials/admin/sidebar") %>

  <main class="flex-1 bg-gray-100 p-6 space-y-6">

    <!-- Page Header -->
    <div>
      <h1 class="text-3xl font-bold text-gray-800">Growth Analytics</h1>
      <p class="text-gray-600">User & Course growth overview</p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <div class="bg-white p-6 rounded-xl shadow">
        <p class="text-sm text-gray-500">Total Users</p>
        <h2 class="text-2xl font-bold">12,450</h2>
      </div>

      <div class="bg-white p-6 rounded-xl shadow">
        <p class="text-sm text-gray-500">Active Students</p>
        <h2 class="text-2xl font-bold">9,820</h2>
      </div>

      <div class="bg-white p-6 rounded-xl shadow">
        <p class="text-sm text-gray-500">Total Courses</p>
        <h2 class="text-2xl font-bold">145</h2>
      </div>

      <div class="bg-white p-6 rounded-xl shadow">
        <p class="text-sm text-gray-500">Completed Courses</p>
        <h2 class="text-2xl font-bold">98</h2>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- User Growth Chart -->
      <div class="bg-white p-6 rounded-xl shadow">
        <h2 class="text-xl font-semibold mb-4">User Growth</h2>
        <canvas id="userGrowthChart" height="140"></canvas>
      </div>

      <!-- Course Growth Chart -->
      <div class="bg-white p-6 rounded-xl shadow">
        <h2 class="text-xl font-semibold mb-4">Course Growth</h2>
        <canvas id="courseGrowthChart" height="140"></canvas>
      </div>

    </div>

  </main>
</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  /* User Growth Chart */
  const userCtx = document.getElementById('userGrowthChart').getContext('2d');

  new Chart(userCtx, {
    type: 'line',
    data: {
      labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'],
      datasets: [{
        label: 'Users',
        data: [1200, 1800, 2600, 3800, 5200, 7800, 12450],
        borderWidth: 3,
        tension: 0.4,
        fill: true,
        backgroundColor: 'rgba(16, 185, 129, 0.15)',
        borderColor: 'rgba(16, 185, 129, 1)',
        pointBackgroundColor: '#10b981'
      }]
    },
    options: {
      responsive: true,
      scales: {
        y: {
          beginAtZero: true
        }
      }
    }
  });

  /* Course Growth Chart */
  const courseCtx = document.getElementById('courseGrowthChart').getContext('2d');

  new Chart(courseCtx, {
    type: 'bar',
    data: {
      labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'],
      datasets: [{
        label: 'Courses',
        data: [10, 18, 30, 48, 72, 100, 145],
        backgroundColor: 'rgba(59, 130, 246, 0.7)'
      }]
    },
    options: {
      responsive: true,
      scales: {
        y: {
          beginAtZero: true
        }
      }
    }
  });
</script>
