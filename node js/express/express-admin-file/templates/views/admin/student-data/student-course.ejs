<%- include("../../../partials/admin/navbar") %>

<div class="flex">
  <%- include("../../../partials/admin/sidebar") %>

  <main class="flex-1 p-6 bg-gray-100 min-h-screen">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-800">Students Management</h1>
        <p class="text-sm text-gray-500">
          Manage all registered students and their activity
        </p>
      </div>

      <div class="flex gap-3 mt-4 md:mt-0">
        <input
          type="text"
          placeholder="Search name or email..."
          class="bg-white border rounded-lg px-4 py-2 text-sm shadow focus:outline-none"
        />
        <select class="bg-white border rounded-lg px-4 py-2 text-sm shadow">
          <option>All Status</option>
          <option>Active</option>
          <option>Inactive</option>
          <option>Banned</option>
        </select>
        <button class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700">
          + Add Student
        </button>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Total Enquiry</h3>
        <p class="text-3xl font-bold text-gray-800"> <%= enrollments.length %></p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Active</h3>
        <p class="text-3xl font-bold text-green-600">420</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Inactive</h3>
        <p class="text-3xl font-bold text-yellow-600">95</p>
       </div>

      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Banned</h3>
        <p class="text-3xl font-bold text-red-600">25</p>
      </div>
    </div>

    <!-- Table -->
     <table class="w-full border border-gray-200 rounded-lg">
  <thead class="bg-blue-600 text-white">
    <tr>
      <th class="p-3 text-left">Student</th>
      <th class="p-3 text-left">Course</th>
      <th class="p-3 text-left">Phone</th>
      <th class="p-3 text-left">Message</th>
      <th class="p-3 text-left">Enrolled At</th>
      <th class="p-3 text-left">Actions</th>
    </tr>
  </thead>

  <tbody class="text-gray-700">
    <% enrollments.forEach(student => { %>
      <tr class="border-t hover:bg-gray-50">
        <td class="p-4">
          <p class="font-semibold"><%= student.name %></p>
          <p class="text-xs text-gray-500"><%= student.email %></p>
        </td>

        <td class="p-4">
          <span class="bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full text-xs">
            <%= student.course %>
          </span>
        </td>

        <td class="p-4"><%= student.phone %></td>

        <td class="p-4 text-sm text-gray-600">
          <%= student.message || "—" %>
        </td>

        <td class="p-4">
          <%= new Date(student.created_at).toLocaleDateString() %>
        </td>

        <td class="p-4">
          <form
            action="/admin/student-course/delete/<%= student.id %>"
            method="POST"
            onsubmit="return confirm('Delete enrollment?')"
          >
            <button class="bg-red-100 text-red-600 px-3 py-1 rounded text-xs hover:bg-red-200">
              Delete
            </button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

  </main>
</div>
