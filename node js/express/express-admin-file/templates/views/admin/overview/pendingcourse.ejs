<%- include("../../../partials/admin/navbar") %>

<div class="flex">
  <%- include("../../../partials/admin/sidebar") %>

  <main class="flex-1 p-6 bg-gray-100 min-h-screen">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-800">Pending Courses</h1>
        <p class="text-sm text-gray-500">
          Review and approve newly submitted courses
        </p>
      </div>

      <div class="flex gap-3 mt-4 md:mt-0">
        <input
          type="text"
          placeholder="Search course..."
          class="bg-white border rounded-lg px-4 py-2 text-sm shadow focus:outline-none"
        />

        <select class="bg-white border rounded-lg px-4 py-2 text-sm shadow">
          <option value="">All Categories</option>
          <option>Web Development</option>
          <option>Design</option>
          <option>Marketing</option>
        </select>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-6">
      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Total Pending</h3>
        <p class="text-3xl font-bold text-yellow-600">12</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Approved Today</h3>
        <p class="text-3xl font-bold text-green-600">4</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Rejected</h3>
        <p class="text-3xl font-bold text-red-600">2</p>
      </div>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl shadow overflow-hidden">

      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-600">
          <tr>
            <th class="p-4 text-left">Course</th>
            <th class="p-4 text-left">Instructor</th>
            <th class="p-4 text-left">Category</th>
            <th class="p-4 text-left">Submitted</th>
            <th class="p-4 text-left">Status</th>
            <th class="p-4 text-right">Actions</th>
          </tr>
        </thead>

        <tbody class="text-gray-700">
          <tr class="border-t hover:bg-gray-50 transition">
            <td class="p-4">
              <p class="font-semibold">React Basics</p>
              <p class="text-xs text-gray-500">12 Lessons • Beginner</p>
            </td>
            <td class="p-4">John Doe</td>
            <td class="p-4">Web Development</td>
            <td class="p-4">06 Jan 2026</td>
            <td class="p-4">
              <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-xs">
                Pending
              </span>
            </td>
            <td class="p-4 text-right">
              <div class="flex justify-end gap-2">
                <button class="bg-green-600 text-white px-3 py-1 rounded-lg hover:bg-green-700 text-xs">
                  Approve
                </button>
                <button class="bg-red-100 text-red-600 px-3 py-1 rounded-lg hover:bg-red-200 text-xs">
                  Reject
                </button>
                <button class="bg-gray-100 text-gray-600 px-3 py-1 rounded-lg hover:bg-gray-200 text-xs">
                  View
                </button>
              </div>
            </td>
          </tr>

          <!-- More rows dynamically -->
        </tbody>
      </table>

      <!-- Empty State -->
      <!--
      <div class="p-10 text-center text-gray-500">
        No pending courses 🎉
      </div>
      -->

    </div>

  </main>
</div>
