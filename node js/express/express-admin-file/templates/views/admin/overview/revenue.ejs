<%- include("../../../partials/admin/navbar") %>

<div class="flex">
  <%- include("../../../partials/admin/sidebar") %>

  <main class="flex-1 p-6 bg-gray-100 min-h-screen">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-800">Revenue Overview</h1>
        <p class="text-sm text-gray-500">Track earnings, payments & growth</p>
      </div>

      <select class="bg-white border rounded-lg px-4 py-2 text-sm shadow">
        <option>Last 7 Days</option>
        <option>Last 30 Days</option>
        <option selected>This Year</option>
      </select>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div class="bg-white p-6 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Today Revenue</h3>
        <p class="text-3xl font-bold text-gray-800 mt-1">₹2,000</p>
        <p class="text-xs text-green-600 mt-2">▲ 12% from yesterday</p>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Monthly Revenue</h3>
        <p class="text-3xl font-bold text-gray-800 mt-1">₹45,000</p>
        <p class="text-xs text-green-600 mt-2">▲ 8% this month</p>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Yearly Revenue</h3>
        <p class="text-3xl font-bold text-gray-800 mt-1">₹3,20,000</p>
        <p class="text-xs text-green-600 mt-2">▲ 21% YoY</p>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Pending Payments</h3>
        <p class="text-3xl font-bold text-red-600 mt-1">₹5,000</p>
        <p class="text-xs text-red-500 mt-2">▼ Needs attention</p>
      </div>
    </div>

    <!-- Revenue Breakdown -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white p-6 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Paid Amount</h3>
        <p class="text-2xl font-bold text-green-600 mt-1">₹3,10,000</p>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Refunded</h3>
        <p class="text-2xl font-bold text-yellow-500 mt-1">₹10,000</p>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Net Revenue</h3>
        <p class="text-2xl font-bold text-indigo-600 mt-1">₹3,00,000</p>
      </div>
    </div>

    <!-- Chart Placeholder -->
    <div class="bg-white rounded-2xl shadow p-6 mb-8">
      <h3 class="text-lg font-semibold text-gray-700 mb-4">
        Monthly Revenue Growth
      </h3>
      <div class="h-64 flex items-center justify-center text-gray-400 border-2 border-dashed rounded-lg">
        Revenue Chart (Chart.js / ApexCharts)
      </div>
    </div>

    <!-- Recent Transactions -->
    <div class="bg-white rounded-2xl shadow p-6">
      <h3 class="text-lg font-semibold text-gray-700 mb-4">
        Recent Transactions
      </h3>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b">
              <th class="pb-3">User</th>
              <th class="pb-3">Plan</th>
              <th class="pb-3">Amount</th>
              <th class="pb-3">Status</th>
              <th class="pb-3">Date</th>
            </tr>
          </thead>
          <tbody class="text-gray-700">
            <tr class="border-b">
              <td class="py-3">Rahul Sharma</td>
              <td>Pro</td>
              <td class="font-semibold">₹1,499</td>
              <td>
                <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs">
                  Paid
                </span>
              </td>
              <td>06 Jan 2026</td>
            </tr>

            <tr class="border-b">
              <td class="py-3">Anita Verma</td>
              <td>Premium</td>
              <td class="font-semibold">₹2,999</td>
              <td>
                <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-xs">
                  Pending
                </span>
              </td>
              <td>05 Jan 2026</td>
            </tr>

            <tr>
              <td class="py-3">Amit Patel</td>
              <td>Basic</td>
              <td class="font-semibold">₹499</td>
              <td>
                <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs">
                  Refunded
                </span>
              </td>
              <td>04 Jan 2026</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  </main>
</div>
