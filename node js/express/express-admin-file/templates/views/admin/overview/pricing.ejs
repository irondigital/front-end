<%- include("../../../partials/admin/navbar") %>

<div class="flex">
  <%- include("../../../partials/admin/sidebar") %>

  <main class="flex-1 p-6 bg-gray-100 min-h-screen">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-gray-800">Pricing Management</h1>
      <button class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-700 transition">
        + Add New Plan
      </button>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <!-- Basic Plan -->
      <div class="bg-white rounded-2xl shadow-lg p-6 relative">
        <span class="absolute top-4 right-4 bg-gray-200 text-gray-700 text-xs px-3 py-1 rounded-full">
          Active
        </span>

        <h3 class="text-lg font-semibold text-gray-700">Basic Plan</h3>
        <p class="text-4xl font-bold text-gray-900 mt-2">₹499</p>
        <p class="text-sm text-gray-500 mb-4">Per month</p>

        <ul class="space-y-2 text-sm text-gray-600 mb-6">
          <li>✔ Access to basic courses</li>
          <li>✔ Email support</li>
          <li>✖ Certificate access</li>
          <li>✖ Live classes</li>
        </ul>

        <div class="flex gap-3">
          <button class="flex-1 bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700">
            Edit
          </button>
          <button class="flex-1 bg-red-100 text-red-600 py-2 rounded-lg hover:bg-red-200">
            Disable
          </button>
        </div>
      </div>

      <!-- Pro Plan (Most Popular) -->
      <div class="bg-white rounded-2xl shadow-xl p-6 border-2 border-indigo-600 relative">
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-indigo-600 text-white text-xs px-4 py-1 rounded-full">
          Most Popular
        </span>

        <span class="absolute top-4 right-4 bg-green-100 text-green-700 text-xs px-3 py-1 rounded-full">
          Active
        </span>

        <h3 class="text-lg font-semibold text-gray-700">Pro Plan</h3>
        <p class="text-4xl font-bold text-indigo-600 mt-2">₹1,499</p>
        <p class="text-sm text-gray-500 mb-4">Per month</p>

        <ul class="space-y-2 text-sm text-gray-600 mb-6">
          <li>✔ All basic features</li>
          <li>✔ Certificates</li>
          <li>✔ Priority support</li>
          <li>✔ Limited live classes</li>
        </ul>

        <div class="flex gap-3">
          <button class="flex-1 bg-indigo-600 text-white py-2 rounded-lg hover:bg-indigo-700">
            Edit
          </button>
          <button class="flex-1 bg-red-100 text-red-600 py-2 rounded-lg hover:bg-red-200">
            Disable
          </button>
        </div>
      </div>

      <!-- Premium Plan -->
      <div class="bg-white rounded-2xl shadow-lg p-6 relative">
        <span class="absolute top-4 right-4 bg-gray-200 text-gray-700 text-xs px-3 py-1 rounded-full">
          Inactive
        </span>

        <h3 class="text-lg font-semibold text-gray-700">Premium Plan</h3>
        <p class="text-4xl font-bold text-gray-900 mt-2">₹2,999</p>
        <p class="text-sm text-gray-500 mb-4">Per month</p>

        <ul class="space-y-2 text-sm text-gray-600 mb-6">
          <li>✔ All Pro features</li>
          <li>✔ Unlimited live classes</li>
          <li>✔ 1-on-1 mentorship</li>
          <li>✔ Dedicated support</li>
        </ul>

        <div class="flex gap-3">
          <button class="flex-1 bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700">
            Edit
          </button>
          <button class="flex-1 bg-green-100 text-green-600 py-2 rounded-lg hover:bg-green-200">
            Enable
          </button>
        </div>
      </div>

    </div>
  </main>
</div>

