<%- include("../../../partials/admin/navbar") %>

<div class="flex">
  <%- include("../../../partials/admin/sidebar") %>

  <main class="flex-1 p-6 bg-gray-100 min-h-screen">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-800">Completed Courses</h1>
        <p class="text-sm text-gray-500">
          View courses successfully completed by instructors
        </p>
      </div>

      <div class="flex gap-3 mt-4 md:mt-0">
        <input
          type="text"
          placeholder="Search course..."
          class="bg-white border rounded-lg px-4 py-2 text-sm shadow focus:outline-none"
        />
        <select class="bg-white border rounded-lg px-4 py-2 text-sm shadow">
          <option>All Instructors</option>
          <option>Jane Smith</option>
          <option>John Doe</option>
        </select>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-6">
      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Total Completed</h3>
        <p class="text-3xl font-bold text-green-600">86</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Completed This Month</h3>
        <p class="text-3xl font-bold text-indigo-600">14</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow">
        <h3 class="text-sm text-gray-500">Certificates Issued</h3>
        <p class="text-3xl font-bold text-gray-800">78</p>
      </div>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl shadow overflow-hidden">

      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-600">
          <tr>
            <th class="p-4 text-left">Course</th>
            <th class="p-4 text-left">Instructor</th>
            <th class="p-4 text-left">Category</th>
            <th class="p-4 text-left">Students</th>
            <th class="p-4 text-left">Rating</th>
            <th class="p-4 text-left">Completion Date</th>
            <th class="p-4 text-right">Actions</th>
          </tr>
        </thead>

        <tbody class="text-gray-700">
          <tr class="border-t hover:bg-gray-50 transition">
            <td class="p-4">
              <p class="font-semibold">Node.js Mastery</p>
              <p class="text-xs text-gray-500">24 Lessons • Advanced</p>
            </td>
            <td class="p-4">Jane Smith</td>
            <td class="p-4">Backend Development</td>
            <td class="p-4">1,240</td>
            <td class="p-4 text-yellow-500">★★★★☆ (4.6)</td>
            <td class="p-4">
              <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs">
                05 Jan 2026
              </span>
            </td>
            <td class="p-4 text-right">
              <div class="flex justify-end gap-2">
                <button class="bg-indigo-600 text-white px-3 py-1 rounded-lg hover:bg-indigo-700 text-xs">
                  View
                </button>
                <button class="bg-green-100 text-green-600 px-3 py-1 rounded-lg hover:bg-green-200 text-xs">
                  Certificate
                </button>
                <button class="bg-gray-100 text-gray-600 px-3 py-1 rounded-lg hover:bg-gray-200 text-xs">
                  Report
                </button>
              </div>
            </td>
          </tr>

          <!-- Dynamic rows from DB -->
        </tbody>
      </table>

      <!-- Empty State -->
      <!--
      <div class="p-10 text-center text-gray-500">
        No completed courses yet 📘
      </div>
      -->

    </div>

  </main>
</div>
