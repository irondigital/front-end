<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Our Services | Greenary</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white">

  <section class="min-h-screen py-16 px-6 md:px-20">
    <div class="max-w-6xl mx-auto">

      <!-- Header -->
      <h1 class="text-4xl md:text-5xl font-bold text-green-700 mb-6">
        Our Services
      </h1>
      <p class="text-gray-700 text-lg mb-12">
        We provide complete green solutions designed for modern homes,
        offices, and sustainable living.
      </p>

      <!-- Services Grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">

        <div class="border p-6 rounded-2xl shadow-sm hover:shadow-lg transition">
          <h3 class="text-xl font-semibold text-green-600 mb-3">
            Indoor Plants
          </h3>
          <p class="text-gray-600">
            Air-purifying and low-maintenance plants perfect for homes and
            offices.
          </p>
        </div>

        <div class="border p-6 rounded-2xl shadow-sm hover:shadow-lg transition">
          <h3 class="text-xl font-semibold text-green-600 mb-3">
            Outdoor & Garden Plants
          </h3>
          <p class="text-gray-600">
            Decorative plants for balconies, gardens, and outdoor landscapes.
          </p>
        </div>

        <div class="border p-6 rounded-2xl shadow-sm hover:shadow-lg transition">
          <h3 class="text-xl font-semibold text-green-600 mb-3">
            Pots & Planters
          </h3>
          <p class="text-gray-600">
            Modern, stylish, and eco-friendly pots and accessories.
          </p>
        </div>

        <div class="border p-6 rounded-2xl shadow-sm hover:shadow-lg transition">
          <h3 class="text-xl font-semibold text-green-600 mb-3">
            Plant Care & Maintenance
          </h3>
          <p class="text-gray-600">
            Expert guidance to help your plants stay healthy and grow better.
          </p>
        </div>

        <div class="border p-6 rounded-2xl shadow-sm hover:shadow-lg transition">
          <h3 class="text-xl font-semibold text-green-600 mb-3">
            Office Green Solutions
          </h3>
          <p class="text-gray-600">
            Professional greenery setups for offices and commercial spaces.
          </p>
        </div>

        <div class="border p-6 rounded-2xl shadow-sm hover:shadow-lg transition">
          <h3 class="text-xl font-semibold text-green-600 mb-3">
            Eco & Sustainability
          </h3>
          <p class="text-gray-600">
            Sustainable sourcing, eco packaging, and green living support.
          </p>
        </div>

      </div>
    </div>
  </section>

</body>
</html>
