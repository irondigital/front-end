<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Us | Greenary</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-green-50">

  <section class="min-h-screen py-16 px-6 md:px-20">
    <div class="max-w-6xl mx-auto">

      <!-- Header -->
      <h1 class="text-4xl md:text-5xl font-bold text-green-700 mb-6">
        About Greenary
      </h1>
      <p class="text-gray-700 text-lg leading-relaxed mb-12">
        Greenary is a modern green lifestyle brand focused on bringing nature
        closer to everyday life. We believe plants are essential for healthy,
        peaceful, and sustainable living.
      </p>

      <!-- Mission & Vision -->
      <div class="grid md:grid-cols-2 gap-10">
        <div class="bg-white p-8 rounded-2xl shadow-md">
          <h2 class="text-2xl font-semibold text-green-600 mb-4">
            Our Mission
          </h2>
          <p class="text-gray-600 leading-relaxed">
            Our mission is to reconnect people with nature by providing
            high-quality plants that are easy to care for and environmentally
            responsible.
          </p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-md">
          <h2 class="text-2xl font-semibold text-green-600 mb-4">
            Our Vision
          </h2>
          <p class="text-gray-600 leading-relaxed">
            To create greener homes, healthier workplaces, and a sustainable
            future where people and nature grow together.
          </p>
        </div>
      </div>

      <!-- Values -->
      <div class="mt-16 bg-white p-10 rounded-2xl shadow-md">
        <h2 class="text-3xl font-semibold text-green-700 mb-6">
          Why Choose Greenary?
        </h2>
        <ul class="grid md:grid-cols-2 gap-4 text-gray-600">
          <li>✔ Handpicked healthy plants</li>
          <li>✔ Beginner-friendly care guidance</li>
          <li>✔ Eco-friendly packaging</li>
          <li>✔ Sustainable sourcing</li>
          <li>✔ Modern & affordable designs</li>
          <li>✔ Trusted plant experts</li>
        </ul>
      </div>

    </div>
  </section>

</body>
</html>
